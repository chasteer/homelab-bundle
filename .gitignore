# --- Секреты и локальная конфигурация ---
.env
.env.*
!.env.example
secrets/
**/secrets/
*.pem
*.key
credentials.json
*credentials*.json

# Docker overrides (часто содержат пароли)
docker-compose.override.yml
**/docker-compose.override.yml

# --- Runtime / логи (могут содержать ключи и отчёты инцидентов) ---
logs/
**/logs/
*.log
agent-web/data/
!agent-web/data/.gitkeep

# --- GitHub polling (может содержать webhook secrets) ---
agent-web/github-config/polling.conf
**/github-config/*.conf

# --- IDE (часто SSH/host; не коммитить) ---
.idea/
.vscode/
*.swp
*.swo

# --- Временные и кэш ---
*.tmp
*.temp
*.bak
*.backup
cache/
*.cache
__pycache__/
*.py[cod]
*$py.class
.codegraph/

# --- Системное ---
.DS_Store
Thumbs.db

# --- Python build ---
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
wheels/

# --- Node ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
