# ===== Homelab Agent env.example =====
# Скопируйте этот файл в .env и заполните реальными значениями

# Основные настройки
TZ=UTC
DEBUG=false
LOG_LEVEL=INFO

# Опционально: GitHub webhook / polling
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=

# Настройки базы данных
AGENT_DB_PASSWORD=your_secure_password_here

# Сетевые настройки (замените на ваши реальные адреса)
HOMELAB_HOST=your_local_ip_here
UPTIME_KUMA_URL=http://your_local_ip:3001
AGENT_WEBHOOK_URL=http://your_local_ip:8000/api/webhook/uptime-kuma

# VPS настройки (замените на ваш реальный VPS)
VPS_WEBHOOK_URL=https://your_vps_domain.com/api/uptime-alerts

# Настройки RAG
RAG_DB_DIR=/app/data/index

# Настройки логирования
LOG_FILE=/app/logs/homelab-agent.log

# Uptime Kuma API key (Prometheus /metrics only)
UPTIME_KUMA_API=your_kuma_api_key

# Cursor CLI — https://cursor.com/dashboard → API Keys
CURSOR_API_KEY=your_cursor_api_key
CURSOR_CLI_PATH=/home/agent/.local/bin/agent
CURSOR_WORKSPACE=/app/homelab
CURSOR_AGENT_MODEL=
CURSOR_AGENT_MODE=ask
CURSOR_TELEGRAM_MAX_CHARS=1400
CURSOR_OUTPUT_FORMAT=json
CURSOR_CLI_TIMEOUT=300
CURSOR_INCIDENT_ENABLED=true
CURSOR_INCIDENT_REQUIRED=true
