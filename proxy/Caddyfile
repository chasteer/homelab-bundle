# Генерируется scripts/30_deploy_proxy_caddy.sh
{
	local_certs

}



torrserver.home.arpa {
	encode gzip
	reverse_proxy http://torrserver:8090
	tls internal
}

immich.home.arpa {
	encode gzip
	reverse_proxy http://immich-server:2283
	tls internal
}

vaultwarden.home.arpa {
	encode gzip
	reverse_proxy http://vaultwarden:80 {
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}
	}
	tls internal
}

kuma.home.arpa {
	encode gzip
	reverse_proxy http://uptime-kuma:3001
	tls internal
}

agent.home.arpa {
	reverse_proxy http://homelab-agent:8000
	tls internal
}

jellyfin.home.arpa {
	encode gzip
	reverse_proxy http://jellyfin:8096
	tls internal
}

it-tools.home.arpa {
	encode gzip
	reverse_proxy http://it-tools:80
	tls internal
}

dozzle.home.arpa {
	encode gzip
	reverse_proxy http://dozzle:8080
	tls internal
}

homeassistant.home.arpa {
	encode gzip
	reverse_proxy http://homeassistant:8123 {
		header_up Host {host}
		header_up X-Forwarded-Host {host}
		header_up X-Forwarded-Proto {scheme}
		header_up X-Forwarded-For {remote_host}
	}
	tls internal
}
